# MongoDB Connection Configuration
# Copy this file to .env and fill in your values

# Full MongoDB connection URI (takes priority over individual fields if set)
MONGO_URI=mongodb://localhost:27017

# Individual connection fields (used when MONGO_URI is not set)
MONGO_HOST=localhost
MONGO_PORT=27017
MONGO_USER=
MONGO_PASSWORD=
MONGO_DB=

# Backend server port
PORT=3001
